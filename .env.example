# 复制为 .env 后填写（.env 不会提交到 git）
# cp .env.example .env

# ---------- 云端大模型（DashScope / 百炼）----------
# 在 https://dashscope.console.aliyun.com/ 创建 API Key
DASHSCOPE_API_KEY=REPLACE_WITH_YOUR_DASHSCOPE_API_KEY

# 国内默认；国际版改为 https://dashscope-intl.aliyuncs.com/compatible-mode/v1
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 文字问诊模型
DASHSCOPE_MODEL=qwen3.7-plus

# 拍照识药（多模态）模型，按控制台实际名称调整
DASHSCOPE_VISION_MODEL=qwen-vl-max

# qwen3.7-plus 默认会「深度思考」，首字约慢 3~4 秒；问诊场景建议关闭
DASHSCOPE_ENABLE_THINKING=0

# 1=文字/识图走云端；0=仍走板子本地 demo LLM
CHAT_USE_CLOUD_LLM=1

# 云端开启后建议关闭本地 NPU 大模型，demo 只负责 ASR/摄像头
CHAT_USE_DEMO_LLM=0

# ---------- 云端 TTS（CosyVoice）----------
# 1=用阿里云 CosyVoice 播报；0=仍走 demo 本地 TTS
TTS_USE_CLOUD=1
COSYVOICE_MODEL=cosyvoice-v3-flash
COSYVOICE_VOICE=longanyang
COSYVOICE_FORMAT=wav
COSYVOICE_SAMPLE_RATE=22050
COSYVOICE_SPEECH_RATE=1.05
# 流式回答合并到该长度再播报（整段一次 TTS，减少句间停顿）
COSYVOICE_BATCH_MAX_CHARS=100
# 首段达到该字数就先开口（重启后第一次体感更快）
COSYVOICE_FIRST_BATCH_CHARS=24
# API 启动后预热云端 LLM + TTS + RAG
CLOUD_WARMUP=1
# 板端播放命令（wav 文件路径会自动追加在末尾）
TTS_PLAY_COMMAND="aplay -q"

# ---------- 关键词唤醒（说「豆包」唤醒，再说问题/拍照）----------
WAKE_ENABLED=1
VOICE_WAKE_WORD=豆包

# ---------- 板端 demo（语音/摄像头）----------
DEMO_CONTROL_URL=http://127.0.0.1:8765
REMINDER_ENABLED=1

# 语音停录：停顿多久算「说完了」（老人说话可设更长）
# VAD_MIN_SILENCE_SEC=1.4
# ASR_SILENCE_END_MS=2200
# ASR_MAX_AFTER_SPEECH_SEC=25
# 用药提醒按北京时间判断（板子系统时区可能是 UTC）
REMINDER_TZ=Asia/Shanghai

# ---------- Server酱微信推送（家属通知）----------
# 在 https://sct.ftqq.com/ 获取 SendKey，不填则关闭所有推送
# SERVERCHAN_KEY=SCTxxxxxxxxxxxxx
# 用药逾期多久推送家属微信（分钟，默认15）
# NOTIFY_OVERDUE_MINUTES=15
# 每日健康日报推送时间（24小时制，默认晚8点）
# NOTIFY_DAILY_HOUR=20
# 同类消息防重复间隔（秒，默认600）
# NOTIFY_COOLDOWN_SEC=600
